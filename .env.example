# ============================================
# lankHub 环境变量配置
# 使用方法：复制此文件为 .env 并修改对应值
#   cp .env.example .env
# ============================================

# 数据库路径（SQLite）
# 本地开发用相对路径，服务器建议用绝对路径
DATABASE_URL="file:./dev.db"

# Auth.js 密钥 — 用于加密 JWT session
# 生成方式：openssl rand -base64 32
AUTH_SECRET="请替换为随机生成的密钥"

# 网站域名（Auth.js 回调用 + sitemap/robots）
NEXTAUTH_URL="http://localhost:3000"

# 公开访问的网站 URL（用于 sitemap、robots.txt）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
